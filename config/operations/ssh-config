# ~/.ssh/config -- snippet to append, git deployment
#
# Reference only -- see config/README.md. This is a block to append
# to the deploying user's existing ~/.ssh/config on the Ubuntu Server
# host, not a complete replacement of that file.
#
# Not tied to a version step -- this is part of the "operations"
# workflow (turning the live deployment into a tracked git working
# tree), which can be done any time after v1, independent of which
# stack versions are deployed.
#
# Source: guides/operations/git-deployment-guide.md section 3
# (SSH Deploy Key Setup)
#
# Stack/container: none -- this is host/git tooling, not a Docker
# stack. Generate the keypair first:
#   ssh-keygen -t ed25519 -C "ubuntu-server-homelab" -f ~/.ssh/homelab_deploy -N ""
# then add the public key as a deploy key (with write access) on the
# GitHub repo before using this block.

Host github-homelab
  HostName github.com
  User git
  IdentityFile ~/.ssh/homelab_deploy
  IdentitiesOnly yes
