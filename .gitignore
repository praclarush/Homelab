# ==============================
# HomeLab Docker Repository
# ==============================

# Environment secrets
.env
.env.*
!.env.example

# ==============================
# Docker
# ==============================

# Docker overrides
docker-compose.override.yml

# Docker runtime data
**/docker-data/
**/data/

# Container logs
**/*.log
logs/

# ==============================
# Databases
# ==============================

# PostgreSQL
**/postgres/
**/postgresql/
**/pgdata/

# Redis / cache data
**/redis/
**/cache/

# SQLite databases
**/*.sqlite
**/*.sqlite3
**/*.db

# SQLite WAL/SHM sidecar files (not matched by the patterns above)
**/*.db-shm
**/*.db-wal
**/*.sqlite-shm
**/*.sqlite-wal
**/*.sqlite3-shm
**/*.sqlite3-wal

# ==============================
# Application Persistent Data
# (paths match the current stacks/<stack>/ layout)
# ==============================

# Immich generated data (model-cache holds multi-GB ML models)
**/immich/model-cache/

# AMP game server data
**/amp/datastore/

# Home Assistant runtime/secret files (.storage holds auth tokens, device credentials)
**/homeassistant/config/.storage/
**/homeassistant/config/home-assistant.log*
**/homeassistant/config/secrets.yaml
**/homeassistant/config/.cloud/
**/homeassistant/config/deps/
**/homeassistant/config/tts/
**/homeassistant/config/.ha_run.lock

# HACS and HACS-managed integrations (downloaded vendor code, not hand-authored config)
**/homeassistant/config/custom_components/

# Pi-hole runtime data and admin password hash (pihole.toml lives here)
**/pihole/config/

# Tailscale node identity/keys
**/tailscale/state/

# Nginx Proxy Manager certificates and runtime data
**/npm/letsencrypt/
**/npm/logs/
**/npm/data/

# Ollama model binaries (multi-GB, never config)
**/llm/models/

# Open WebUI uploaded files
**/open-webui/uploads/

# ESPHome secrets (WiFi credentials, API/OTA keys)
**/esphome/secrets.yaml

# Paperless-ngx ingested/processed documents
**/paperless/media/
**/paperless/consume/

# CrowdSec: cscli-managed hub content (vendored parsers/scenarios, symlinked
# into the container at /etc/crowdsec/hub -- reinstalled by cscli, not hand-authored),
# downloaded blocklists/GeoIP databases, and notification profiles (contain
# webhook URLs/API tokens)
**/crowdsec/data/
**/crowdsec/config/hub/
**/crowdsec/config/local_api_credentials.yaml
**/crowdsec/config/online_api_credentials.yaml
**/crowdsec/config/notifications/
**/crowdsec/config/scenarios/
**/crowdsec/config/collections/
**/crowdsec/config/postoverflows/
**/crowdsec/config/parsers/
**/crowdsec/config/contexts/
**/crowdsec/config/patterns/

# Self-managed app data with no separate static-config layer -- everything
# under these paths is written by the app itself (SQLite DBs, metadata caches,
# session stores, user-generated content), not hand-authored config
**/audiobookshelf/
**/jellyfin/
**/kavita/
**/actual-budget/
**/grocy/
**/mealie/
**/n8n/
**/pgadmin/
**/stirling-pdf/

# ==============================
# Backups
# ==============================

backup/
backups/
*.bak
*.backup
*.tar
*.tar.gz

# ==============================
# OS / Editor Files
# ==============================

.DS_Store
Thumbs.db

.vscode/
.idea/

*.swp
*.swo
*~

# ==============================
# Secrets / Certificates
# ==============================

*.pem
*.key
*.crt
*.p12
*.secret

# ==============================
# Temporary Files
# ==============================

tmp/
temp/
.cache/

# Keep example configuration files
!.env.example
/.vs
