# /etc/fstab -- NFS lines
#
# Reference only -- see config/README.md. These are the NFS mount
# lines to APPEND to the host's existing /etc/fstab. Do not overwrite
# the file; it also contains your root partition, swap, and any other
# host-specific entries not shown here.
#
# Source: guides/getting-started/homelab-guide.md section 2.2 (Mount
# the NAS Shares) -- this is the single place all six shares below are
# created and mounted, before any stack that depends on one first
# deploys. media-gaming-guide.md and tools-guide.md only confirm these
# mounts are present; they don't create them.
#
# Replace <nas-ip> with your Synology's actual IP, and the
# /volume1/... paths with your actual NAS shared folder paths if they
# differ.

<nas-ip>:/volume1/immich   /mnt/synology/immich   nfs   defaults   0 0
# ^ media-gaming stack: Immich (immich-server) -- photo/video uploads.

<nas-ip>:/volume1/media    /mnt/synology/media    nfs   defaults   0 0
# ^ media-gaming stack: Jellyfin -- media library source.

<nas-ip>:/volume1/audiobooks   /mnt/synology/audiobooks   nfs   defaults   0 0
# ^ media-gaming stack: Audiobookshelf -- audiobook library.

<nas-ip>:/volume1/podcasts     /mnt/synology/podcasts     nfs   defaults   0 0
# ^ media-gaming stack: Audiobookshelf -- podcast library.

<nas-ip>:/volume1/books        /mnt/synology/books        nfs   defaults   0 0
# ^ media-gaming stack: Kavita -- ebook/comic/manga library.

<nas-ip>:/volume1/backups   /mnt/synology/backups   nfs   defaults   0 0
# ^ auth, media-gaming, tools stacks: nightly Postgres pg_dump sidecars
#   (Authentik, Immich, WikiJS, Paperless-ngx, Linkwarden) write to
#   /mnt/synology/backups/postgres-dumps/<service>/ here. tools stack:
#   Backrest also uses this share as its restic backup destination for
#   /opt/docker/stacks.
