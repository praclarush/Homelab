# Copy to secrets.yaml (gitignored) in the same folder before running
# `esphome run rack-ble-proxy.yaml`. Never commit the real secrets.yaml.

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

# Fallback AP password ESPHome broadcasts if it can't join the network above.
# Must be at least 8 characters.
wifi_fallback_password: "changeme123"

# 32-byte base64 key for the encrypted HA <-> ESPHome API connection.
# Generate with: openssl rand -base64 32
api_encryption_key: "GENERATE_ME"

# Password for OTA firmware updates after the initial USB flash.
ota_password: "changeme123"
